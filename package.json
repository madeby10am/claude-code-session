{
  "name": "claude-code-session",
  "publisher": "madeby10am",
  "displayName": "Claude Code Session",
  "description": "Monitor Claude Code sessions with a pixel art companion -- live activity badges, gradient border glows, token tracking, and an animated robot sidebar.",
  "version": "2.0.0",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/madeby10am/claude-code-session"
  },
  "homepage": "https://github.com/madeby10am/claude-code-session#readme",
  "bugs": {
    "url": "https://github.com/madeby10am/claude-code-session/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "session",
    "monitor",
    "pixel-art",
    "sidebar"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-session.open",
        "title": "Claude Code Session: Open as Split Panel"
      }
    ],
    "keybindings": [
      {
        "command": "claude-code-session.open",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-session",
          "title": "Claude Code Session",
          "icon": "assets/icon-light.svg"
        }
      ]
    },
    "views": {
      "claude-code-session": [
        {
          "type": "webview",
          "id": "claude-code-session.sidebar",
          "name": "Claude Sessions"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview && npm run copy:webview-static",
    "build:webview": "esbuild src/webview/index.ts --bundle --outfile=out/webview/bundle.js --format=iife --target=es2020",
    "copy:webview-static": "mkdir -p out/webview && cp src/webview/styles.css src/webview/body.html out/webview/",
    "deploy": "npm run compile && for d in ~/.vscode/extensions/local.claude-code-session-*/; do mkdir -p \"$d/out/session\" \"$d/out/webview\" && cp out/*.js \"$d/out/\" && cp out/session/*.js \"$d/out/session/\" && cp out/webview/bundle.js out/webview/styles.css out/webview/body.html \"$d/out/webview/\" && cp package.json \"$d/package.json\"; done",
    "watch": "tsc -watch -p ./",
    "watch:webview": "esbuild src/webview/index.ts --bundle --outfile=out/webview/bundle.js --format=iife --target=es2020 --watch",
    "generate-sprites": "ts-node --project tsconfig.scripts.json scripts/generate-sprites.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "canvas": "^3.2.3",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
