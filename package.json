{
  "name": "claude-code-session",
  "publisher": "local",
  "displayName": "Claude Code Session",
  "description": "Monitor Claude Code sessions with a pixel art companion",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-session.open",
        "title": "Claude Code Session: Open as Split Panel"
      }
    ],
    "keybindings": [
      {
        "command": "claude-code-session.open",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-session",
          "title": "Claude Code Session",
          "icon": "assets/icon-light.svg"
        }
      ]
    },
    "views": {
      "claude-code-session": [
        {
          "type": "webview",
          "id": "claude-code-session.sidebar",
          "name": "Claude Sessions"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "deploy": "tsc -p ./ && cp out/panel.js out/extension.js out/sessionManager.js ~/.vscode/extensions/local.claude-code-session-0.0.1/out/ && cp package.json ~/.vscode/extensions/local.claude-code-session-0.0.1/package.json",
    "watch": "tsc -watch -p ./",
    "generate-sprites": "ts-node --project tsconfig.scripts.json scripts/generate-sprites.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "canvas": "^3.2.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
